# ============================================
# GOLD PRICE PREDICTOR - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your keys

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# News API Key (free at https://newsapi.org)
NEWS_API_KEY=your-newsapi-key-here

# FRED API Key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your-fred-api-key-here

# Optional: Model configuration
OPENAI_MODEL=gpt-4o
TEMPERATURE=0.2

# Optional: Refresh interval in minutes
REFRESH_INTERVAL_MINUTES=30

# ── AWS S3 Cloud Storage (replaces GitHub Gist) ─────────────────────
# Create an S3 bucket and an IAM user with read/write access to it.
# Add these to Streamlit secrets (or .env):
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION=ap-south-2
AWS_S3_PREFIX=gold-predictor/

# ── Legacy Gist (no longer needed, kept for reference) ──────────────
# GITHUB_GIST_TOKEN=ghp_...
# GITHUB_GIST_ID=abc123...

# ============================================
# GOLD PRICE PREDICTOR - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your keys

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# News API Key (free at https://newsapi.org)
NEWS_API_KEY=your-newsapi-key-here

# FRED API Key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your-fred-api-key-here

# Optional: Model configuration
OPENAI_MODEL=gpt-4o
TEMPERATURE=0.2

# Optional: Refresh interval in minutes
REFRESH_INTERVAL_MINUTES=30

# ── AWS S3 Cloud Storage (primary backend) ───────────────────────────
# Credentials come from IAM role / default boto3 chain — no keys needed here.
# Only configure the bucket name (and optionally region/prefix).
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION=ap-south-2
AWS_S3_PREFIX=gold-predictor/

# ── GitHub Gist (fallback when S3 is unavailable) ───────────────────
# Create a Personal Access Token with *gist* scope and a private Gist.
GITHUB_GIST_TOKEN=ghp_your-token-here
GITHUB_GIST_ID=your-gist-id-here
